name: HUB CertSecure — Sync

on:
  schedule:
    - cron: '0 */4 * * *'
  workflow_dispatch:

jobs:

  sync-evident:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v6

      - name: Set up Node.js
        uses: actions/setup-node@v5
        with:
          node-version: "24"

      - name: Run Evident sync
        env:
          EVIDENT_KEY_AGEQUIPMENT:      ${{ secrets.EVIDENT_KEY_AGEQUIPMENT }}
          EVIDENT_KEY_ACTIONPLUMBING:   ${{ secrets.EVIDENT_KEY_ACTIONPLUMBING }}
          EVIDENT_KEY_BAUERFOUNDATION:  ${{ secrets.EVIDENT_KEY_BAUERFOUNDATION }}
          EVIDENT_KEY_CPKANSASCITY:     ${{ secrets.EVIDENT_KEY_CPKANSASCITY }}
          EVIDENT_KEY_CAPITALROAD:      ${{ secrets.EVIDENT_KEY_CAPITALROAD }}
          EVIDENT_KEY_EMMES:            ${{ secrets.EVIDENT_KEY_EMMES }}
          EVIDENT_KEY_EMERYSAPPANDSONS: ${{ secrets.EVIDENT_KEY_EMERYSAPPANDSONS }}
          EVIDENT_KEY_GARTPROPERTIES:   ${{ secrets.EVIDENT_KEY_GARTPROPERTIES }}
          EVIDENT_KEY_KOLBGRADING:      ${{ secrets.EVIDENT_KEY_KOLBGRADING }}
          EVIDENT_KEY_MIZUHOBANK:       ${{ secrets.EVIDENT_KEY_MIZUHOBANK }}
          EVIDENT_KEY_MUSSELMANHALL:    ${{ secrets.EVIDENT_KEY_MUSSELMANHALL }}
          EVIDENT_KEY_PARAGONGEO:       ${{ secrets.EVIDENT_KEY_PARAGONGEO }}
          EVIDENT_KEY_SCANDROLI:        ${{ secrets.EVIDENT_KEY_SCANDROLI }}
          EVIDENT_KEY_SKYLINE:          ${{ secrets.EVIDENT_KEY_SKYLINE }}
          EVIDENT_KEY_THEABBEYCOMPANY:  ${{ secrets.EVIDENT_KEY_THEABBEYCOMPANY }}
          EVIDENT_KEY_TRINITYCHEMICAL:  ${{ secrets.EVIDENT_KEY_TRINITYCHEMICAL }}
          EVIDENT_KEY_UNITEDCOAL:       ${{ secrets.EVIDENT_KEY_UNITEDCOAL }}
        run: node evident-sync/src/sync.js

      - name: Run engagement sync (Google Sheets)
        env:
          GOOGLE_SERVICE_ACCOUNT_KEY: ${{ secrets.GOOGLE_SERVICE_ACCOUNT_KEY }}
          GOOGLE_SHEET_ID:            ${{ secrets.GOOGLE_SHEET_ID }}
          GOOGLE_SHEET_TAB:           Email Events
        continue-on-error: true
        run: node evident-sync/src/sync-engagement.js

      - name: Run custom properties sync
        env:
          EVIDENT_KEY_AGEQUIPMENT:      ${{ secrets.EVIDENT_KEY_AGEQUIPMENT }}
          EVIDENT_KEY_ACTIONPLUMBING:   ${{ secrets.EVIDENT_KEY_ACTIONPLUMBING }}
          EVIDENT_KEY_BAUERFOUNDATION:  ${{ secrets.EVIDENT_KEY_BAUERFOUNDATION }}
          EVIDENT_KEY_CPKANSASCITY:     ${{ secrets.EVIDENT_KEY_CPKANSASCITY }}
          EVIDENT_KEY_CAPITALROAD:      ${{ secrets.EVIDENT_KEY_CAPITALROAD }}
          EVIDENT_KEY_EMMES:            ${{ secrets.EVIDENT_KEY_EMMES }}
          EVIDENT_KEY_EMERYSAPPANDSONS: ${{ secrets.EVIDENT_KEY_EMERYSAPPANDSONS }}
          EVIDENT_KEY_GARTPROPERTIES:   ${{ secrets.EVIDENT_KEY_GARTPROPERTIES }}
          EVIDENT_KEY_KOLBGRADING:      ${{ secrets.EVIDENT_KEY_KOLBGRADING }}
          EVIDENT_KEY_MIZUHOBANK:       ${{ secrets.EVIDENT_KEY_MIZUHOBANK }}
          EVIDENT_KEY_MUSSELMANHALL:    ${{ secrets.EVIDENT_KEY_MUSSELMANHALL }}
          EVIDENT_KEY_PARAGONGEO:       ${{ secrets.EVIDENT_KEY_PARAGONGEO }}
          EVIDENT_KEY_SCANDROLI:        ${{ secrets.EVIDENT_KEY_SCANDROLI }}
          EVIDENT_KEY_SKYLINE:          ${{ secrets.EVIDENT_KEY_SKYLINE }}
          EVIDENT_KEY_THEABBEYCOMPANY:  ${{ secrets.EVIDENT_KEY_THEABBEYCOMPANY }}
          EVIDENT_KEY_TRINITYCHEMICAL:  ${{ secrets.EVIDENT_KEY_TRINITYCHEMICAL }}
          EVIDENT_KEY_UNITEDCOAL:       ${{ secrets.EVIDENT_KEY_UNITEDCOAL }}
        run: node evident-sync/src/sync-custom-properties.js

      - name: Route CSVs to data/evident/
        run: |
          mkdir -p data/evident

          # Move any CSVs from repo-root data/ (written by sync.js)
          find data -maxdepth 1 -name "*.csv" | while IFS= read -r f; do
            mv "$f" data/evident/
            echo "  moved from data/: $f"
          done

          # Also capture CSVs from evident-sync/data/
          if [ -d "evident-sync/data" ]; then
            find evident-sync/data -maxdepth 1 -name "*.csv" | while IFS= read -r f; do
              fname=$(basename "$f")
              lines=$(wc -l < "$f")
              if [ "$lines" -gt 1 ]; then
                cp "$f" "data/evident/$fname"
                echo "  copied from evident-sync/data/: $fname ($lines rows)"
              else
                echo "  skipped (empty): $fname"
              fi
            done
          fi

          echo "Final data/evident/ contents:"
          ls -lh data/evident/*.csv 2>/dev/null | awk '{print "  " $5, $9}'

      - name: Snapshot Evident data — monthly + daily
        run: |
          DATE=$(date -u +'%Y-%m-%d')
          MONTH="${DATE:0:7}"
          YEAR="${DATE:0:4}"

          # ── 1. Monthly snapshot ──────────────────────────────────
          # Used by: Year mode, Month mode, Year End Review, Producer Overview
          # Path: snapshots/YYYY/YYYY-MM/
          MONTHLY="snapshots/$YEAR/$MONTH"
          mkdir -p "$MONTHLY"
          M_COUNT=0
          for f in data/evident/*.csv; do
            if [ -f "$f" ]; then
              cp "$f" "$MONTHLY/"
              M_COUNT=$((M_COUNT + 1))
            fi
          done
          echo "Evident monthly snapshot: $MONTHLY ($M_COUNT files)"

          # ── 2. Daily snapshot ────────────────────────────────────
          # Used by: Date Range mode in Producer Overview
          # Path: snapshots/daily/YYYY/YYYY-MM-DD/
          DAILY="snapshots/daily/$YEAR/$DATE"
          mkdir -p "$DAILY"
          D_COUNT=0
          for f in data/evident/*.csv; do
            if [ -f "$f" ]; then
              cp "$f" "$DAILY/"
              D_COUNT=$((D_COUNT + 1))
            fi
          done
          echo "Evident daily snapshot:   $DAILY ($D_COUNT files)"

      - name: Commit Evident data and snapshots
        run: |
          git config user.name  "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add data/evident/ snapshots/
          git diff --cached --quiet || git commit -m "sync: update Evident CSVs [$(date -u '+%Y-%m-%d %H:%M UTC')]"
          git pull --rebase -X ours
          if git rebase --show-current-patch >/dev/null 2>&1; then
            git diff --name-only --diff-filter=U | xargs -r git checkout --ours --
            git diff --name-only --diff-filter=U | xargs -r git add
            git rebase --continue --no-edit
          fi
          git push

  sync-trustlayer:
    needs: [sync-evident]
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v6

      - name: Set up Node.js
        uses: actions/setup-node@v5
        with:
          node-version: "24"

      - name: Pull raw data from TrustLayer API
        env:
          TL_TOKEN_BLOCK_REAL_ESTATE:  ${{ secrets.TL_TOKEN_BLOCK_REAL_ESTATE }}
          TL_TOKEN_CMI:                ${{ secrets.TL_TOKEN_CMI }}
          TL_TOKEN_QTS:                ${{ secrets.TL_TOKEN_QTS }}
          TL_TOKEN_EXCEL_CONSTRUCTORS: ${{ secrets.TL_TOKEN_EXCEL_CONSTRUCTORS }}
          TL_TOKEN_DEMOCLIENT:         ${{ secrets.TL_TOKEN_DEMOCLIENT }}
        run: node trustlayer-sync/src/sync.js

      - name: Transform to Evident-compatible format
        run: node trustlayer-sync/src/transform.js

      - name: Route CSVs to data/trustlayer/
        run: |
          mkdir -p data/trustlayer
          if [ -d "trustlayer-sync/data" ]; then
            find trustlayer-sync/data -maxdepth 1 -name "*.csv" | while IFS= read -r f; do
              fname=$(basename "$f")
              lines=$(wc -l < "$f" 2>/dev/null || echo 0)
              if [ "$lines" -gt 0 ]; then
                cp "$f" "data/trustlayer/$fname"
                echo "  copied: $fname ($lines rows)"
              else
                echo "  skipped (empty): $fname"
              fi
            done
          fi
          echo "Route complete"
          echo "Final data/trustlayer/ contents:"
          ls -lh data/trustlayer/*.csv 2>/dev/null | awk '{print "  " $5, $9}'

      - name: Snapshot TrustLayer data — monthly + daily
        run: |
          DATE=$(date -u +'%Y-%m-%d')
          MONTH="${DATE:0:7}"
          YEAR="${DATE:0:4}"

          # ── 1. Monthly snapshot ──────────────────────────────────
          # Merge the 3 transform-output files into the combined
          # Evident+TL snapshot so the app reports can read them.
          # Also copies ALL raw TL CSVs with a tl_ prefix.
          # Path: snapshots/YYYY/YYYY-MM/
          MONTHLY="snapshots/$YEAR/$MONTH"
          mkdir -p "$MONTHLY"

          # Raw TL CSVs — prefix tl_ so they don't overwrite Evident files
          TL_M_COUNT=0
          for f in data/trustlayer/*.csv; do
            if [ -f "$f" ]; then
              fname=$(basename "$f")
              cp "$f" "$MONTHLY/tl_${fname}"
              TL_M_COUNT=$((TL_M_COUNT + 1))
              echo "  monthly tl_${fname}"
            fi
          done

          # Merge insureds / coverages / criteria into the combined snapshot
          for f in data/trustlayer/insureds.csv data/trustlayer/coverages.csv data/trustlayer/criteria.csv; do
            fname=$(basename "$f")
            lines=$(wc -l < "$f" 2>/dev/null || echo 0)
            if [ "$lines" -gt 1 ]; then
              if [ -f "$MONTHLY/$fname" ]; then
                ev_file="data/evident/$fname"
                if [ -f "$ev_file" ]; then
                  cp "$ev_file" "$MONTHLY/$fname"
                fi
                tail -n +2 "$f" >> "$MONTHLY/$fname"
                echo "  merged TL rows into $MONTHLY/$fname"
              else
                cp "$f" "$MONTHLY/$fname"
                echo "  created $MONTHLY/$fname (TL only)"
              fi
            fi
          done
          echo "TrustLayer monthly snapshot: $MONTHLY ($TL_M_COUNT raw files + 3 merged)"

          # ── 2. Daily snapshot ────────────────────────────────────
          # Path: snapshots/daily/YYYY/YYYY-MM-DD/
          DAILY="snapshots/daily/$YEAR/$DATE"
          mkdir -p "$DAILY"

          # Raw TL CSVs
          TL_D_COUNT=0
          for f in data/trustlayer/*.csv; do
            if [ -f "$f" ]; then
              fname=$(basename "$f")
              cp "$f" "$DAILY/tl_${fname}"
              TL_D_COUNT=$((TL_D_COUNT + 1))
            fi
          done

          # Merge insureds / coverages / criteria for date range lookups
          for f in data/trustlayer/insureds.csv data/trustlayer/coverages.csv data/trustlayer/criteria.csv; do
            fname=$(basename "$f")
            lines=$(wc -l < "$f" 2>/dev/null || echo 0)
            if [ "$lines" -gt 1 ]; then
              if [ -f "$DAILY/$fname" ]; then
                ev_file="data/evident/$fname"
                if [ -f "$ev_file" ]; then
                  cp "$ev_file" "$DAILY/$fname"
                fi
                tail -n +2 "$f" >> "$DAILY/$fname"
              else
                cp "$f" "$DAILY/$fname"
              fi
            fi
          done
          echo "TrustLayer daily snapshot:   $DAILY ($TL_D_COUNT raw files + 3 merged)"

      - name: Commit TrustLayer data and snapshots
        run: |
          git config user.name  "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add data/trustlayer/ snapshots/
          git diff --cached --quiet || git commit -m "sync: update TrustLayer CSVs [$(date -u '+%Y-%m-%d %H:%M UTC')]"
          git pull --rebase -X ours
          if git rebase --show-current-patch >/dev/null 2>&1; then
            git diff --name-only --diff-filter=U | xargs -r git checkout --ours --
            git diff --name-only --diff-filter=U | xargs -r git add
            git rebase --continue --no-edit
          fi
          git push
